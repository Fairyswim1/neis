{
  "manifest_version": 3,
  "name": "나이스 입력 도우미",
  "version": "1.0.0",
  "description": "엑셀 데이터를 나이스(NEIS) 입력창에 자동으로 붙여넣습니다.",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation"],
  "host_permissions": [
    "*://*.neis.go.kr/*",
    "*://*.eduptl.kr/*",
    "*://*.go.kr/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "나이스 입력 도우미",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.neis.go.kr/*",
        "*://*.eduptl.kr/*"
      ],
      "js": ["content/content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  }
}
