{
  "name": "neis-input-helper",
  "version": "1.0.0",
  "description": "엑셀 데이터를 나이스(NEIS) 입력창에 자동으로 붙여넣는 Chrome 확장 프로그램",
  "scripts": {
    "icons": "node scripts/generate-icons.js",
    "postinstall": "node -e \"const fs=require('fs');const p='lib/xlsx.full.min.js';if(!fs.existsSync(p)){fs.mkdirSync('lib',{recursive:true});fs.copyFileSync('node_modules/xlsx/dist/xlsx.full.min.js',p);}\""
  },
  "keywords": ["neis", "chrome-extension", "excel", "education"],
  "author": "Fairyswim1",
  "license": "MIT",
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
